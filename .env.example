# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Numeric chat ID (user, group, or channel) where digests are delivered
TELEGRAM_CHAT_ID=123456789

# OpenAI
OPENAI_API_KEY=sk-...
# Optional: model for filtering / ranking / summaries (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Daily schedule (24h clock, in TIMEZONE)
DIGEST_HOUR=8
DIGEST_MINUTE=0
TIMEZONE=America/New_York

# Optional: override RSS feed list as JSON array of URLs
# NEWS_RSS_FEEDS=["https://example.com/feed.xml"]

# Optional tuning
# LOOKBACK_HOURS=36
# MAX_ITEMS_IN_DIGEST=8
# MAX_CANDIDATES_FOR_OPENAI=35
# HTTP_TIMEOUT_SECONDS=20
# LOG_LEVEL=INFO
